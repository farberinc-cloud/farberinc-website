# ============================================================
# Farber.Inc — .htaccess
# Canonical host: www.farberinc.media
# Canonical URL: strip /index.html, force trailing slash
# Compress text assets, set caching headers
# ============================================================

# ---- Force HTTPS + www ----
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^farberinc\.media$ [NC]
RewriteRule ^(.*)$ https://www.farberinc.media/$1 [R=301,L]

# ---- Strip /index.html → / ----
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ https://%{HTTP_HOST}/ [R=301,L]

# ---- Strip trailing .html from clean URLs (e.g. /pages/services/ai-consulting.html
#      stays as-is since that's how Hostinger serves static files; this rewrite
#      is opt-in only if you later add a router) ----
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^([^/]+)/?$ $1.html [L]

# ---- Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ---- Caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# ---- Security headers ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
